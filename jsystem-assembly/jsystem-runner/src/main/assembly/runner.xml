<assembly
	xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
	<formats>
		<format>tar.gz</format>
		<format>zip</format>
		<format>dir</format>
	</formats>
	<id>runner</id>
	<dependencySets>
		<dependencySet>
			<outputDirectory>thirdparty</outputDirectory>
			<unpack>true</unpack>
			<directoryMode>774</directoryMode>
			<fileMode>774</fileMode>
			<includes>
				<include>ant:ant-full:*</include>
			</includes>
			<unpackOptions>
				<excludes>
					<exclude>ant/docs/**</exclude>
				</excludes>
			</unpackOptions>
		</dependencySet>
		<dependencySet>
			<outputDirectory>projects/jsystemServices/target/classes</outputDirectory>
			<unpack>true</unpack>
			<includes>
				<include>*:jsystem-services-tests:*</include>
			</includes>
		</dependencySet>
		<dependencySet>
			<outputDirectory>projects/jsystemServices/src/main/java</outputDirectory>
			<unpack>true</unpack>
			<includes>
				<include>*:jsystem-services-tests:*:sources:*</include>
			</includes>
			<unpackOptions>
				<includes>
					<include>**/*.java</include>
				</includes>
			</unpackOptions>
		</dependencySet>
		<dependencySet>
			<outputDirectory>projects/jsystemServices/src/main/resources</outputDirectory>
			<unpack>true</unpack>
			<includes>
				<include>*:jsystem-services-tests:*:sources:*</include>
			</includes>
			<unpackOptions>
				<includes>
					<include>**/*.xml</include>
					<include>**/*.properties</include>
				</includes>
			</unpackOptions>
		</dependencySet>
		<dependencySet>
			<outputDirectory>projects/jsystemServices/lib</outputDirectory>
			<unpack>false</unpack>
			<includes>
				<include>*:jsystem-services-so:*</include>
			</includes>
		</dependencySet>


		<dependencySet>
			<outputDirectory>thirdparty/ant/lib</outputDirectory>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<includes>
				<include>*:ant-contrib:*</include>
			</includes>
		</dependencySet>
		<dependencySet>
			<outputDirectory>thirdparty/commonLib</outputDirectory>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<includes>
				<include>*:*:*</include>
			</includes>
			<excludes>
				<exclude>org.jsystemtest:*:*</exclude>
				<exclude>org.jsystemtest.systemobjects:*:*</exclude>
				<exclude>ant:ant-full:*</exclude>
				<exclude>org.apache.ant:ant:*</exclude>
				<exclude>org.apache.ant:ant-launcher:*</exclude>
				<exclude>ant-contrib:ant-contrib:*</exclude>
				<exclude>*:jsystem-services-tests:*:sources:*</exclude>
			</excludes>
		</dependencySet>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<includes>
				<include>org.jsystemtest:*:jar</include>
				<include>org.jsystemtest.systemobjects:*:jar</include>
			</includes>
			<excludes>
				<exclude>*:jsystem-services-so:*</exclude>
				<exclude>*:jsystem-services-tests:*</exclude>
				<exclude>*:jsystem-runner:*</exclude>
			</excludes>
		</dependencySet>
	</dependencySets>
	<fileSets>
		<fileSet>
			<outputDirectory>dev</outputDirectory>
			<directory>src/main/dev</directory>
		</fileSet>
		<fileSet>
			<outputDirectory></outputDirectory>
			<directory>src/main/etc</directory>
			<excludes>
				<exclude>run</exclude>
				<exclude>runBase</exclude>
				<exclude>runAgent</exclude>
			</excludes>
		</fileSet>
		<fileSet>
			<outputDirectory></outputDirectory>
			<directory>src/main/etc</directory>
			<fileMode>775</fileMode>
			<includes>
				<include>run</include>
				<include>runBase</include>
				<include>runAgent</include>
			</includes>
		</fileSet>

	</fileSets>

</assembly>